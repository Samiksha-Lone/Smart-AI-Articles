# MONGODB URL
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/beyondchats?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS configuration in production)
FRONTEND_URL=http://localhost:5173

# Ollama Configuration (Free, Open-Source Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral


# AI Provider Keys
# Priority order: Gemini (production) → Ollama (local)

# Gemini API Key - FREE production tier (recommended)
# Get your key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here