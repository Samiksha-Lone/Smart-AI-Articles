# MONGODB URL
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/beyondchats?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS configuration in production)
FRONTEND_URL=http://localhost:5173

# Ollama Configuration (Free, Open-Source Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Redis Configuration (for BullMQ queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI API Key (for AI enhancement)
OPENAI_API_KEY=your_openai_api_key_here